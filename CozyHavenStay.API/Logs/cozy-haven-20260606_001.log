SELECT [s].[HotelId], [s].[HotelName], [s].[c], [s].[c0], [s0].[BookingId], [s0].[GuestName], [s0].[CheckInDate], [s0].[CheckOutDate], [s0].[TotalFare], [s0].[BookingStatus], [s0].[RoomId], [s0].[HotelId], [s0].[UserId]
FROM (
    SELECT [h].[HotelId], [h].[HotelName], COUNT(*) AS [c], COALESCE(SUM([b].[TotalFare]), 0.0) AS [c0]
    FROM [Bookings] AS [b]
    INNER JOIN [Rooms] AS [r] ON [b].[RoomId] = [r].[RoomId]
    INNER JOIN [Hotels] AS [h] ON [r].[HotelId] = [h].[HotelId]
    WHERE [b].[BookingStatus] <> N'Cancelled' OR [b].[BookingStatus] IS NULL
    GROUP BY [h].[HotelId], [h].[HotelName]
) AS [s]
LEFT JOIN (
    SELECT [b0].[BookingId], [u].[FullName] AS [GuestName], [b0].[CheckInDate], [b0].[CheckOutDate], [b0].[TotalFare], [b0].[BookingStatus], [r0].[RoomId], [h0].[HotelId], [u].[UserId], [b0].[BookingDate], [h0].[HotelName]
    FROM [Bookings] AS [b0]
    INNER JOIN [Rooms] AS [r0] ON [b0].[RoomId] = [r0].[RoomId]
    INNER JOIN [Hotels] AS [h0] ON [r0].[HotelId] = [h0].[HotelId]
    INNER JOIN [Users] AS [u] ON [b0].[UserId] = [u].[UserId]
    WHERE [b0].[BookingStatus] <> N'Cancelled' OR [b0].[BookingStatus] IS NULL
) AS [s0] ON [s].[HotelId] = [s0].[HotelId] AND [s].[HotelName] = [s0].[HotelName]
ORDER BY [s].[HotelId], [s].[HotelName], [s0].[BookingDate] DESC, [s0].[BookingId], [s0].[RoomId], [s0].[HotelId]
